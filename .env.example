# Copy this to .env and fill in the values

# Port the Express server listens on
PORT=3000

# bcrypt-hashed admin list — generate with: node scripts/hash-password.js <password>
ADMINS_JSON=[{"username":"edmund","passwordHash":"$2a$10$..."}]

# 32-byte random hex — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Optional: override where timetable-data.json is stored (default: ./data/timetable-data.json)
# DATA_PATH=/absolute/path/to/timetable-data.json
